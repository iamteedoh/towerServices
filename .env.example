# Copy to .env (gitignored) and fill in for YOUR environment.
#   cp .env.example .env && $EDITOR .env
# bridge/deploy.sh sources this and renders bridge/k8s/*.tmpl with envsubst.

# --- container image -------------------------------------------------------
# Your registry (host:port) and image name. Examples:
#   registry.example.com:5000   or   ghcr.io/youruser
REGISTRY=registry.example.com:5000
IMAGE=towerservices-bridge
IMAGE_TAG=latest

# --- kubernetes ------------------------------------------------------------
K8S_NAMESPACE=default
# NodePort the bridge is exposed on (pick a free one in your cluster).
BRIDGE_NODEPORT=30091

# --- homepage / clients ----------------------------------------------------
# Base URL clients (Homepage) use to reach the bridge. In-cluster you can use
# the Service DNS name; from a browser use the NodePort or an ingress host.
BRIDGE_URL=http://towerservices-bridge.default.svc:8080
# UI to link the status tile through to (e.g. your AWX/AAP web UI).
TOWER_UI_URL=http://localhost:8080
# Browser-facing AWX UI (redirect target for the /go/awx gate + job links).
# With the reverse-proxy in front, this is the PROXY's URL.
AWX_PUBLIC_URL=http://localhost:30083
# --- AWX reverse-proxy (proxy/k8s); only if you front AWX with the proxy ----
AWX_PROXY_NODEPORT=30083                              # AWX's old NodePort
AWX_UPSTREAM=awx-service.awx.svc.cluster.local:80     # AWX Service (ClusterIP)
BRIDGE_UPSTREAM=towerservices-bridge.default.svc.cluster.local:8080
# CORS: origins allowed to call the action endpoints from a browser (the
# dashboard). REQUIRED for the dashboard buttons — comma-separated; empty means
# no cross-origin is accepted (fail closed). "*" allows any (trusted LAN only).
CORS_ORIGINS=http://homepage.example.lan:30089

---
# Template — rendered by bridge/deploy.sh via envsubst (${...} from .env).
# Do not hardcode environment-specific values here; keep them in .env.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: towerservices-bridge
  namespace: ${K8S_NAMESPACE}
  labels: { app: towerservices-bridge }
spec:
  replicas: 1
  selector:
    matchLabels: { app: towerservices-bridge }
  template:
    metadata:
      labels: { app: towerservices-bridge }
    spec:
      containers:
        - name: bridge
          image: ${REGISTRY}/${IMAGE}:${IMAGE_TAG}
          imagePullPolicy: Always
          ports:
            - containerPort: 8080
          env:
            - name: TOWERSERVICES_TOKEN
              valueFrom:
                secretKeyRef: { name: towerservices-bridge, key: token }
            - name: TOWERSERVICES_STATUS_DIR
              value: /var/run/towerservices
            - name: TOWERSERVICES_CORS_ORIGINS
              value: "${CORS_ORIGINS}"
            # AWX API for graceful pause/resume (drain). Optional: the bridge
            # still runs without it; only pause/resume need it. Create with:
            #   kubectl -n ${K8S_NAMESPACE} create secret generic towerservices-awx \
            #     --from-literal=url=http://awx-service.awx.svc \
            #     --from-literal=token=$(awx-manage create_oauth2_token --user admin)
            - name: AWX_API_URL
              valueFrom:
                secretKeyRef: { name: towerservices-awx, key: url, optional: true }
            - name: AWX_API_TOKEN
              valueFrom:
                secretKeyRef: { name: towerservices-awx, key: token, optional: true }
            # Browser-facing AWX UI: the /go/awx gate redirects here when up,
            # and it's the base for links to a job blocking a drain.
            - name: AWX_PUBLIC_URL
              value: "${AWX_PUBLIC_URL}"
            - name: KUBECONFIG
              value: /secrets/kube/config
          volumeMounts:
            - { name: status, mountPath: /var/run/towerservices }
            - { name: kubeconfig, mountPath: /secrets/kube, readOnly: true }
            - { name: sshkey, mountPath: /secrets/ssh, readOnly: true }
          readinessProbe:
            httpGet: { path: /healthz, port: 8080 }
            initialDelaySeconds: 5
          livenessProbe:
            httpGet: { path: /healthz, port: 8080 }
            initialDelaySeconds: 10
      volumes:
        - name: status
          emptyDir: {}
        # kubeconfig for managing the AWX namespace (create from your cluster):
        #   kubectl -n ${K8S_NAMESPACE} create secret generic towerservices-kubeconfig \
        #       --from-file=config=$HOME/.kube/config
        - name: kubeconfig
          secret: { secretName: towerservices-kubeconfig, optional: true }
        # SSH key for reaching AAP/Tower VMs (optional if you only use AWX):
        #   kubectl -n ${K8S_NAMESPACE} create secret generic towerservices-ssh \
        #       --from-file=id_ed25519=/path/to/key
        - name: sshkey
          secret:
            secretName: towerservices-ssh
            optional: true
            defaultMode: 0400
---
apiVersion: v1
kind: Service
metadata:
  name: towerservices-bridge
  namespace: ${K8S_NAMESPACE}
  labels: { app: towerservices-bridge }
spec:
  type: NodePort
  selector: { app: towerservices-bridge }
  ports:
    - port: 8080
      targetPort: 8080
      nodePort: ${BRIDGE_NODEPORT}
